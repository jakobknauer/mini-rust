struct Box<T> {
    ptr: *T,
}

impl<T> Box<T> {
    fn new(val: T) -> Box<T> {
        let ptr = alloc::<T>();
        *ptr = val;
        Box { ptr }
    }

    fn drop(&mut self) {
        delete(self.ptr);
    }
}

impl<T> Deref for Box<T> {
    type Target = T;

    fn deref(&self) -> &T {
        &*self.ptr
    }
}
