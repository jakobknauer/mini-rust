fn malloc(size: isize) -> *c_void;
fn free(alloc: *c_void);

fn size_of<T>() -> isize;

impl<T> *T {
    fn offset(&self, offset: isize) -> *T;
}

fn alloc<T>() -> *T {
    malloc(size_of::<T>()) as *T
}

fn alloc_n<T>(n: isize) -> *T {
    malloc(n * size_of::<T>()) as *T
}

fn delete<T>(ref: *T) {
    free(ref as *c_void)
}
