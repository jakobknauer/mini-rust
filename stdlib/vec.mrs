struct Vec<T> {
    ptr: *T,
    len: isize,
    cap: isize,
}

fn copy_n<T>(src: *T, dst: *T, n: isize) {
    let mut i = 0isize;
    while i < n {
        *dst.offset(i) = *src.offset(i);
        i = i + 1isize;
    }
}

impl<T> Vec<T> {
    fn new() -> Vec<T> {
        let init_cap = 8isize;
        let ptr = alloc_n::<T>(init_cap);
        Vec {
            ptr: ptr,
            len: 0isize,
            cap: init_cap,
        }
    }

    fn push(&mut self, val: T) {
        if self.len == self.cap {
            self.cap = self.cap * 2isize;

            let new_ptr = alloc_n(self.cap);
            copy_n(self.ptr, new_ptr, self.len);

            delete(self.ptr);
            self.ptr = new_ptr;
        }

        *self.ptr.offset(self.len) = val;
        self.len = self.len + 1isize;
    }

    fn len(&self) -> isize { self.len }

    fn get(&self, idx: isize) -> Option<&T> {
        if idx >= self.len || idx < 0isize {
            Option::None
        } else {
            Option::Some { item: &*self.ptr.offset(idx) }
        }
    }

    fn get_mut(&mut self, idx: isize) -> Option<&mut T> {
        if idx >= self.len || idx < 0isize {
            Option::None
        } else {
            Option::Some { item: &mut*self.ptr.offset(idx) }
        }
    }

    fn pop(&mut self) -> Option<T> {
        if self.len == 0isize {
            Option::None
        } else {
            self.len = self.len - 1isize;
            Option::Some { item: *self.ptr.offset(self.len) }
        }
    }

    fn drop(&mut self) {
        self.len = 0isize;
        self.cap = 0isize;
        delete(self.ptr);
    }

    fn iter(&self) -> RefVecIter<T> {
        RefVecIter { vec: self, idx: 0isize }
    }

    fn iter_mut(&mut self) -> RefMutVecIter<T> {
        RefMutVecIter { vec: self, idx: 0isize }
    }
}

impl<A, B> Eq<Vec<B>> for Vec<A>
where
    A: Eq<B>
{
    fn eq(&self, other: &Vec<B>) -> bool {
        if self.len != other.len {
            return false;
        }
        let mut i = 0isize;
        while i < self.len {
            if !(*self.ptr.offset(i) == *other.ptr.offset(i)) {
                return false;
            }
            i = i + 1isize;
        }
        true
    }
}

impl<T> IntoIterator for Vec<T> {
    type Item = T;
    type IntoIter = VecIter<T>;

    fn into_iter(self) -> VecIter<T> {
        VecIter { vec: self, idx: 0isize }
    }
}

struct VecIter<T> {
    vec: Vec<T>,
    idx: isize,
}

impl<T> Iterator for VecIter<T> {
    type Item = T;

    fn next(&mut self) -> Option<T> {
        if self.idx >= self.vec.len {
            Option::None
        } else {
            let item = *self.vec.ptr.offset(self.idx);
            self.idx = self.idx + 1isize;
            Option::Some { item }
        }
    }
}

impl<T> IntoIterator for &Vec<T> {
    type Item = &T;
    type IntoIter = RefVecIter<T>;

    fn into_iter(self) -> RefVecIter<T> {
        RefVecIter { vec: self, idx: 0isize }
    }
}

struct RefVecIter<T> {
    vec: &Vec<T>,
    idx: isize,
}

impl<T> Iterator for RefVecIter<T> {
    type Item = &T;

    fn next(&mut self) -> Option<&T> {
        let next = self.vec.get(self.idx);
        self.idx = self.idx + 1isize;
        next
    }
}

impl<T> IntoIterator for &mut Vec<T> {
    type Item = &mut T;
    type IntoIter = RefMutVecIter<T>;

    fn into_iter(self) -> RefMutVecIter<T> {
        RefMutVecIter { vec: self, idx: 0isize }
    }
}

struct RefMutVecIter<T> {
    vec: &mut Vec<T>,
    idx: isize,
}

impl<T> Iterator for RefMutVecIter<T> {
    type Item = &mut T;

    fn next(&mut self) -> Option<&mut T> {
        let next = self.vec.get_mut(self.idx);
        self.idx = self.idx + 1isize;
        next
    }
}
